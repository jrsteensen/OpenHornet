	(text "Power Management / Switch\n\nVIN1 is Priority Power determined by R7/R8 and PR1 and is from RAW after going thru the MIC5219\nVIN2 is after the 500mA fuse\n\nIf VIN1 is present but not VIN2, +5V is routed from the MC5218 thru the TPS2116 and is +5V\nif VIN2 is Present but not VIN1 then VIN2 is routed thru the TPS2116 to +5V\nIf VIN2 and VIN1 are present then VIN1 is routed thru the TPS2116 to +5v\n"
		(exclude_from_sim no)
		(at 177.165 24.765 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "eb9bb635-df5e-4533-932e-51f0894e0a89")
	)
